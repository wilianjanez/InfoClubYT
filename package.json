    "@remotion/media-utils": "^4.0.190",
    "@remotion/renderer": "^4.0.190",
    "googleapis": "^140.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.190",
    "xlsx": "^0.18.5",
    "zod": "4.3.6"
